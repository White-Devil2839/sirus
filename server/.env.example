# ── SIRUS server environment ──────────────────────────────────
# Copy this file to `.env` and fill in real values.

PORT=5000
NODE_ENV=development

# MongoDB — local or MongoDB Atlas connection string
MONGODB_URI=mongodb://127.0.0.1:27017/sirus

# Auth
JWT_SECRET=change-me-to-a-long-random-string

# CORS — the client origin allowed to call this API
CLIENT_ORIGIN=http://localhost:5173

# ── LLM (Groq — free tier, OpenAI-compatible) ─────────────────
# Get a key at https://console.groq.com/keys . Without one, the app still runs
# and generation returns a realistic seeded report (demo mode).
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Groq's free tier caps tokens-per-minute, so we send at most this many
# transcript characters. Raise it if your tier allows a bigger request.
LLM_MAX_TRANSCRIPT_CHARS=6000

# ── Deepgram (audio/video → diarized transcript) ──────────────
# Free $200 signup credits at https://console.deepgram.com
# Without a key, clients upload written transcripts instead.
DEEPGRAM_API_KEY=
